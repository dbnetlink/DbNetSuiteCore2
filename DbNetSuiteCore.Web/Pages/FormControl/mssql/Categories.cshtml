@page
@using DbNetSuiteCore.Enums
@using DbNetSuiteCore.Web.Enums
@using DbNetSuiteCore.Web.Helpers
@using DbNetSuiteCore.Models
@using Microsoft.Extensions.Primitives
@{
    var categoriesForm = new FormModel(DataSourceType.MSSQL, ConnectionStringHelper.TestConnectionString(Request.Query["db"], DataSourceType.MSSQL), "Categories") { Insert = true, Delete = true};
    categoriesForm.ClientEvents[FormClientEvent.RecordInserted] = "logId";
    @(await DbNetSuiteCore.Control.Create(HttpContext).Render(categoriesForm))
}

<script>
    function logId(sender, args)
    {
        console.log(args.autoincrementValue)
    }
</script>